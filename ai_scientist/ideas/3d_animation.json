[
    {
        "Name": "event_sparse_physics_guided_motion_diffusion",
        "Title": "\u4e8b\u4ef6\u7a00\u758f\u53ef\u5fae\u7269\u7406\u5f15\u5bfc\u76843D\u52a8\u4f5c\u6269\u6563\uff1a\u5728\u4e0d\u91cd\u8bad\u5927\u6a21\u578b\u4e0b\u6d88\u9664\u6ed1\u6b65\u4e0e\u7a7f\u6a21",
        "Short Hypothesis": "\u6838\u5fc3\u95ee\u9898\uff1a\u751f\u6210\u5f0f\u52a8\u4f5c\u6a21\u578b\u4e3a\u4f55\u5728\u89c6\u89c9\u4e0a\u81ea\u7136\u5374\u5728\u7269\u7406\u4e0a\u5931\u771f\uff1f\u6211\u4eec\u7684\u5047\u8bbe\u662f\uff1a\u5927\u591a\u6570\u7269\u7406\u8fdd\u548c\uff08\u6ed1\u6b65\u3001\u811a\u5e95\u6f02\u79fb\u3001\u8f7b\u5fae\u7a7f\u6a21\u3001\u91cd\u5fc3\u6296\u52a8\uff09\u96c6\u4e2d\u53d1\u751f\u5728\u5c11\u91cf\u201c\u63a5\u89e6\u4e8b\u4ef6\u5e27\u201d\u3002\u56e0\u6b64\uff0c\u4e0d\u5fc5\u5bf9\u5168\u5e8f\u5217\u8fdb\u884c\u6602\u8d35\u521a\u4f53\u4eff\u771f\uff0c\u53ea\u9700\u5728\u6269\u6563\u91c7\u6837\u8fc7\u7a0b\u4e2d\u5bf9\u63a5\u89e6\u4e8b\u4ef6\u65bd\u52a0\u53ef\u5fae\u201c\u51b2\u91cf-\u7ea6\u675f\u6295\u5f71\u201d\uff08impulse-constrained projection\uff09\uff0c\u5c31\u80fd\u4ee5\u6781\u4f4e\u8ba1\u7b97\u5f00\u9500\u663e\u8457\u63d0\u5347\u7269\u7406\u4e00\u81f4\u6027\uff0c\u5e76\u4fdd\u6301\u539f\u6a21\u578b\u591a\u6837\u6027\u3002\u8fd9\u4e00\u8bbe\u5b9a\u662f\u6700\u5408\u9002\u7684\uff0c\u56e0\u4e3a\u5b83\u76f4\u63a5\u4f5c\u7528\u4e8e\u9519\u8bef\u53d1\u751f\u7684\u673a\u5236\uff08\u63a5\u89e6\u5207\u6362\uff09\uff0c\u6bd4\u5168\u7a0b\u7269\u7406\u4eff\u771f\u6216\u5b8c\u5168\u91cd\u8bad\u751f\u6210\u5668\u66f4\u9ad8\u6548\u3001\u66f4\u53ef\u590d\u7528\u3002",
        "Related Work": "\u76f8\u5173\u65b9\u5411\u5305\u62ec\uff1a1\uff09\u6587\u672c/\u6761\u4ef6\u4eba\u4f53\u52a8\u4f5c\u6269\u6563\u6a21\u578b\uff08\u5982MDM\u3001MotionDiffuse\uff09\u5728\u8bed\u4e49\u4e0e\u591a\u6837\u6027\u4e0a\u8868\u73b0\u5f3a\uff0c\u4f46\u5e38\u89c1\u811a\u6ed1\u4e0e\u63a5\u89e6\u4e0d\u7a33\uff1b2\uff09\u540e\u5904\u7406\u5f0fIK/\u8f68\u8ff9\u5e73\u6ed1\u53ef\u7f13\u89e3\u5c40\u90e8\u95ee\u9898\uff0c\u4f46\u7f3a\u4e4f\u7edf\u4e00\u7269\u7406\u76ee\u6807\uff0c\u5e38\u727a\u7272\u52a8\u6001\u7ec6\u8282\uff1b3\uff09\u7269\u7406\u89d2\u8272\u63a7\u5236\u4e0e\u53ef\u5fae\u7269\u7406\uff08\u5982Brax/Taichi\u7c7b\u6846\u67b6\u4e2d\u7684\u68af\u5ea6\u4f18\u5316\uff09\u901a\u5e38\u4f9d\u8d56\u4efb\u52a1\u7279\u5b9a\u8bad\u7ec3\u6216\u5f3a\u5316\u5b66\u4e60\uff0c\u8fc1\u79fb\u5230\u751f\u6210\u5f0f\u6d41\u6c34\u7ebf\u6210\u672c\u9ad8\u3002\u6211\u4eec\u7684\u533a\u522b\uff1a\u4e0d\u662f\u201c\u8bad\u7ec3\u4e00\u4e2a\u65b0\u7269\u7406\u751f\u6210\u5668\u201d\uff0c\u4e5f\u4e0d\u662f\u201c\u7eaf\u540e\u5904\u7406\u4fee\u8865\u201d\uff0c\u800c\u662f\u5728\u6269\u6563\u53cd\u63a8\u6bcf\u6b65\u4e2d\u63d2\u5165\u4e8b\u4ef6\u7a00\u758f\u7269\u7406\u68af\u5ea6\u5f15\u5bfc\uff0c\u5e76\u5f15\u5165\u63a5\u89e6\u72b6\u6001\u7f6e\u4fe1\u95e8\u63a7\uff0c\u5f62\u6210\u53ef\u63d2\u62d4\u3001\u8bad\u7ec3\u65e0\u5173\uff08\u6216\u4ec5\u8f7b\u91cf\u5fae\u8c03\uff09\u7684\u65b9\u6cd5\u3002\u8fd9\u4e0d\u662f\u5bf9\u5df2\u6709\u63a5\u89e6\u635f\u5931\u7684\u5e73\u51e1\u6269\u5c55\uff0c\u56e0\u4e3a\u6211\u4eec\u4f18\u5316\u7684\u662f\u2018\u91c7\u6837\u8f68\u8ff9\u4e2d\u7684\u566a\u58f0\u66f4\u65b0\u65b9\u5411\u2019\uff0c\u800c\u975e\u4ec5\u4f18\u5316\u6700\u7ec8\u8f93\u51fa\u3002",
        "Abstract": "\u751f\u6210\u5f0f3D\u89d2\u8272\u52a8\u753b\u5df2\u80fd\u5feb\u901f\u4ea7\u751f\u9ad8\u8d28\u91cf\u52a8\u4f5c\u5e8f\u5217\uff0c\u4f46\u5728\u5de5\u4e1a\u843d\u5730\u4e2d\u4ecd\u53d7\u7269\u7406\u8fdd\u548c\u9650\u5236\uff0c\u5178\u578b\u8868\u73b0\u4e3a\u811a\u6b65\u6ed1\u79fb\u3001\u63a5\u89e6\u7a7f\u900f\u3001\u91cd\u5fc3\u4e0d\u7a33\u5b9a\u3002\u672c\u6587\u63d0\u51fa\u4e00\u79cd\u53ef\u63d2\u62d4\u7684\u4e8b\u4ef6\u7a00\u758f\u53ef\u5fae\u7269\u7406\u5f15\u5bfc\u6846\u67b6\uff08Event-Sparse Physics Guidance, ESPG\uff09\uff0c\u7528\u4e8e\u5728\u4e0d\u91cd\u8bad\u6216\u4ec5\u8f7b\u91cf\u5fae\u8c03\u73b0\u6709\u6269\u6563\u52a8\u4f5c\u6a21\u578b\u7684\u6761\u4ef6\u4e0b\u63d0\u5347\u7269\u7406\u4e00\u81f4\u6027\u3002\u65b9\u6cd5\u6838\u5fc3\u5305\u542b\u4e24\u70b9\uff1a\u5176\u4e00\uff0c\u6784\u5efa\u63a5\u89e6\u4e8b\u4ef6\u68c0\u6d4b\u5668\uff0c\u5728\u53bb\u566a\u8fc7\u7a0b\u52a8\u6001\u5b9a\u4f4d\u8db3\u5e95\u63a5\u5730\u3001\u79bb\u5730\u4e0e\u78b0\u649e\u4e34\u754c\u5e27\uff1b\u5176\u4e8c\uff0c\u5728\u8fd9\u4e9b\u7a00\u758f\u5e27\u4e0a\u6267\u884c\u53ef\u5fae\u51b2\u91cf-\u7ea6\u675f\u6295\u5f71\uff0c\u5c06\u6cd5\u5411\u4e0d\u7a7f\u900f\u3001\u5207\u5411\u6469\u64e6\u9525\u3001\u96f6\u901f\u5ea6\u63a5\u89e6\u4e0e\u91cd\u5fc3\u7a33\u5b9a\u6027\u5199\u4e3a\u53ef\u5fae\u80fd\u91cf\u9879\uff0c\u5e76\u5c06\u5176\u68af\u5ea6\u4f5c\u4e3aclassifier-guidance\u5f0f\u4fee\u6b63\u6ce8\u5165\u6269\u6563\u66f4\u65b0\u3002\u4e3a\u907f\u514d\u8fc7\u7ea6\u675f\u5bfc\u81f4\u52a8\u4f5c\u50f5\u5316\uff0c\u6211\u4eec\u8bbe\u8ba1\u63a5\u89e6\u7f6e\u4fe1\u95e8\u63a7\u4e0e\u8bed\u4e49\u4fdd\u6301\u9879\uff0c\u4ec5\u5728\u9ad8\u7f6e\u4fe1\u7269\u7406\u51b2\u7a81\u65f6\u589e\u5f3a\u7ea6\u675f\u3002\u8be5\u6846\u67b6\u53ef\u517c\u5bb9SMPL\u9aa8\u67b6\u52a8\u4f5c\u4e0e\u901a\u7528\u5173\u8282\u52a8\u753b\uff0c\u5e76\u53ef\u4e0e\u73b0\u6709\u6587\u672c\u5230\u52a8\u4f5c\u6a21\u578b\u76f4\u63a5\u96c6\u6210\u3002\u9884\u671f\u5728HumanML3D\u3001AMASS\u53ca\u6e38\u620f\u52a8\u4f5c\u7247\u6bb5\u4e0a\uff0cESPG\u53ef\u663e\u8457\u964d\u4f4efoot sliding\u4e0epenetration\u6307\u6807\uff0c\u540c\u65f6\u4fdd\u6301FVD/R-Precision\u548c\u52a8\u4f5c\u591a\u6837\u6027\u3002\u8be5\u5de5\u4f5c\u5c55\u793a\u4e86\u201c\u4e8b\u4ef6\u7ea7\u7269\u7406\u5f15\u5bfc\u201d\u4f5c\u4e3a\u751f\u6210\u6a21\u578b\u4e0e\u4eff\u771f\u7ea6\u675f\u4e4b\u95f4\u7684\u4e2d\u95f4\u5c42\u8303\u5f0f\uff0c\u4e3a\u4f4e\u6210\u672c\u3001\u9ad8\u771f\u5b9e\u611f\u76843D\u52a8\u753b\u751f\u4ea7\u63d0\u4f9b\u65b0\u8def\u5f84\u3002",
        "Experiments": [
            "\u5b9e\u9a8c1\uff08\u6838\u5fc3\u6709\u6548\u6027\uff09\uff1a\u5728\u9884\u8bad\u7ec3\u52a8\u4f5c\u6269\u6563\u6a21\u578b\u4e0a\u6bd4\u8f83\u56db\u79cd\u63a8\u7406\u7b56\u7565\uff1a\u65e0\u7ea6\u675f\u3001\u4f20\u7edf\u540e\u5904\u7406IK\u3001\u5168\u5e27\u7269\u7406\u5f15\u5bfc\u3001\u4e8b\u4ef6\u7a00\u758f\u7269\u7406\u5f15\u5bfc\uff08ESPG\uff09\u3002\u6570\u636e\u96c6\uff1aHumanML3D\u3001AMASS\u3002\u6307\u6807\uff1aFoot Sliding Error\uff08\u811a\u63a5\u89e6\u671f\u8db3\u5e95\u901f\u5ea6\uff09\u3001Penetration Depth/Frame\u3001CoM\u7a33\u5b9a\u6027\u6307\u6807\u3001FID/FVD\u3001R-Precision\u3001Diversity\u3002",
            "\u5b9e\u9a8c2\uff08\u5f00\u9500\u4e0e\u6536\u76ca\uff09\uff1a\u6d4b\u91cf\u4e0d\u540c\u65b9\u6cd5\u7684\u63a8\u7406\u65f6\u95f4\u3001\u663e\u5b58\u3001\u6bcf\u5e8f\u5217\u4f18\u5316\u6b65\u6570\uff1b\u7ed8\u5236\u7269\u7406\u8d28\u91cf-\u8ba1\u7b97\u6210\u672cPareto\u66f2\u7ebf\uff0c\u9a8c\u8bc1\u201c\u7a00\u758f\u4e8b\u4ef6\u201d\u76f8\u5bf9\u201c\u5168\u5e27\u7ea6\u675f\u201d\u7684\u6548\u7387\u4f18\u52bf\u3002",
            "\u5b9e\u9a8c3\uff08\u95e8\u63a7\u673a\u5236\u6d88\u878d\uff09\uff1a\u53bb\u9664\u63a5\u89e6\u7f6e\u4fe1\u95e8\u63a7\u3001\u53bb\u9664\u6469\u64e6\u9525\u3001\u53bb\u9664\u51b2\u91cf\u6295\u5f71\uff0c\u4ec5\u4fdd\u7559\u7b80\u5355\u4f4d\u7f6e\u60e9\u7f5a\uff1b\u6bd4\u8f83\u7269\u7406\u6307\u6807\u548c\u8bed\u4e49\u6307\u6807\u53d8\u5316\uff0c\u9a8c\u8bc1\u5404\u7ec4\u4ef6\u5fc5\u8981\u6027\u3002",
            "\u5b9e\u9a8c4\uff08\u6cdb\u5316\u6027\uff09\uff1a\u8de8\u89d2\u8272\u9aa8\u67b6\u6bd4\u4f8b\u3001\u4e0d\u540c\u5730\u5f62\uff08\u5e73\u5730\u3001\u659c\u5761\u3001\u53f0\u9636\uff09\u548c\u4ea4\u4e92\u7269\u4f53\uff08\u7bb1\u4f53\u3001\u5899\u9762\uff09\u8bc4\u4f30\uff0c\u6d4b\u8bd5\u662f\u5426\u4ecd\u80fd\u964d\u4f4e\u7a7f\u900f\u4e0e\u6ed1\u6b65\u3002",
            "\u5b9e\u9a8c5\uff08\u8f7b\u91cf\u5fae\u8c03\u53ef\u9009\uff09\uff1a\u5728\u5c11\u91cf\u6709\u7269\u7406\u6807\u6ce8/\u4f2a\u6807\u6ce8\u6570\u636e\u4e0a\u505aLoRA\u7ea7\u522b\u5fae\u8c03\uff0c\u5bf9\u6bd4\u7eaf\u63a8\u7406\u5f15\u5bfc\uff0c\u8bc4\u4f30\u662f\u5426\u8fdb\u4e00\u6b65\u51cf\u5c11\u4f2a\u63a5\u89e6\u4e0e\u52a8\u4f5c\u6296\u52a8\u3002",
            "\u5b9e\u9a8c6\uff08\u4e3b\u89c2\u8bc4\u6d4b\uff09\uff1a\u53cc\u76f2A/B\u6d4b\u8bd5\uff08\u52a8\u753b\u5e08\u4e0e\u666e\u901a\u7528\u6237\uff09\uff0c\u8bc4\u5206\u7ef4\u5ea6\uff1a\u771f\u5b9e\u611f\u3001\u7a33\u5b9a\u6027\u3001\u81ea\u7136\u5ea6\u3001\u53ef\u7528\u6027\u3002\u62a5\u544a\u4e0e\u5ba2\u89c2\u6307\u6807\u7684\u76f8\u5173\u6027\u3002"
        ],
        "Risk Factors and Limitations": [
            "\u63a5\u89e6\u4e8b\u4ef6\u68c0\u6d4b\u9519\u8bef\u4f1a\u4f20\u64ad\u4e3a\u9519\u8bef\u7269\u7406\u68af\u5ea6\uff0c\u5bfc\u81f4\u5c40\u90e8\u50f5\u786c\u6216\u6296\u52a8\u3002",
            "\u53ef\u5fae\u63a5\u89e6\u6a21\u578b\u901a\u5e38\u662f\u5e73\u6ed1\u8fd1\u4f3c\uff0c\u6781\u7aef\u5feb\u901f\u52a8\u4f5c\u4e0b\u53ef\u80fd\u4e0e\u771f\u5b9e\u521a\u4f53\u52a8\u529b\u5b66\u504f\u5dee\u8f83\u5927\u3002",
            "\u82e5\u539f\u59cb\u751f\u6210\u52a8\u4f5c\u8bed\u4e49\u9519\u8bef\u4e25\u91cd\uff08\u4f8b\u5982\u6b65\u6001\u76f8\u4f4d\u9519\u4e71\uff09\uff0c\u4ec5\u9760\u7269\u7406\u5f15\u5bfc\u96be\u4ee5\u5b8c\u5168\u4fee\u590d\u3002",
            "\u5728\u590d\u6742\u591a\u4eba\u4ea4\u4e92\u6216\u8f6f\u4f53\u670d\u9970\u573a\u666f\u4e0b\uff0c\u5f53\u524d\u521a\u4f53\u8fd1\u4f3c\u53ef\u80fd\u4e0d\u8db3\u3002",
            "\u8bc4\u4ef7\u6307\u6807\u6807\u51c6\u5c1a\u672a\u7edf\u4e00\uff0c\u9700\u516c\u5f00\u5b9e\u73b0\u4e0e\u8bc4\u6d4b\u811a\u672c\u4ee5\u4fdd\u8bc1\u53ef\u590d\u73b0\u6027\u3002"
        ]
    }
]